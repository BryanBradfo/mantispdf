{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MantisPDF",
  "version": "1.0.6",
  "identifier": "com.mantispdf.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MantisPDF",
        "width": 1280,
        "height": 832,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "backgroundColor": "#0a0a0a",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
