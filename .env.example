# MantisPDF — Pro licensing config (ADR 03). All values are PUBLIC identifiers.
# Never put the Lemon Squeezy *secret API key* here: the License API doesn't use
# it, and it must never ship in a distributed client.

# --- Frontend (Vite) -------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in your real values.
# The Lemon Squeezy checkout/permalink the "Upgrade to Pro" CTA links to,
# e.g. https://YOURSTORE.lemonsqueezy.com/buy/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
VITE_MANTIS_CHECKOUT_URL=https://yourstore.lemonsqueezy.com/buy/your-variant-uuid

# --- Backend (Rust, compile-time) ------------------------------------------
# These scope licenses to YOUR product so a key from another store can't unlock
# the app. They are read by `option_env!` at build time, so export them in the
# environment when you build/release, e.g.:
#   LS_VARIANT_ID=123456 LS_STORE_ID=78901 npm run tauri:build
# If unset, the product-scope check is skipped (DEV ONLY — set before shipping).
# LS_VARIANT_ID=123456
# LS_STORE_ID=78901
